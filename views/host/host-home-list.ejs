<%- include('../partials/head') %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    </head>

    <body class="bg-slate-50 min-h-screen font-sans">
        <%- include('../partials/nav') %>

            <main class="py-12">
                <div class="max-w-7xl mx-auto px-6">

                    <h1 class="text-6xl font-serif text-center text-slate-800 mb-12 ">
                        Hey Host! here are your homes

                        <i class="fa-solid fa-house "></i>
                    </h1>

                    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <% registeredHomes.forEach(home=> { %>
                            <li
                                class="bg-white  rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300 hover:-translate-y-1">
                                <!-- House Image -->
                                <div class="overflow-hidden">
                                    <img src="<%= home.photoURL %>" alt="<%= home.houseName %>"
                                        class="w-full h-64 object-cover transition duration-500 hover:scale-105">
                                </div>


                                <!-- Card Content -->
                                <div class="px-5 pt-5 pb-3 ">

                                    <h2 class="text-2xl font-semibold font-serif leading-tight ">
                                        <%= home.houseName %>
                                    </h2>

                                    <p class="flex items-center gap-2 text-gray-500 mt-3">
                                        <i class="fa-solid fa-location-dot "></i>
                                        <%= home.location %>
                                    </p>

                                    <div class="flex items-center justify-between mt-3">

                                        <!-- Price -->
                                        <div class="flex items-end gap-1">
                                            <span class="text-2xl font-bold text-rose-500">
                                                ₹<%= home.price %>
                                            </span>

                                            <span class="text-gray-500 text-sm mb-1">
                                                / night
                                            </span>
                                        </div>

                                        <!-- Rating -->
                                        <span class="text-yellow-500 font-semibold">
                                            <i class="fa-solid fa-star text-yellow-400"></i>
                                            <%= home.rating %>
                                        </span>

                                    </div>

                                    <hr class="my-2 border-gray-200">
                                    <div class="mt-3 mb-2 ml-2 mr-2 flex gap-4 ">

                                        <!-- Edit Button -->
                                        <a href="/host/edit-home/<%=home.id%>?editing=true" class="flex-1 flex    items-center        justify-center gap-2 py-2 rounded-xl
                                        border border-blue-500 text-blue-600 bg-white
                                        font-semibold text-lg
                                        hover:bg-blue-500 hover:text-white
                                        transition-all duration-300">

                                            <i class="fa-solid fa-pen"></i>
                                            Edit Details
                                        </a>

                                        <!-- Delete Button -->
                                        <form action="/host/delete-home/<%= home.id %>" method="POST" class="flex-1">
                                            <button type="submit"
                                            class="w-full flex items-center justify-center gap-2 py-2 rounded-xl
                                                        border border-red-500 text-red-500 bg-white
                                                        font-semibold text-lg
                                                        hover:bg-red-500 hover:text-white
                                                        transition-all duration-300">

                                                <i class="fa-solid fa-trash"></i>
                                                Delete
                                            </button>
                                        </form>

                                    </div>

                            </li>
                            <% }) %>
                    </ul>

                </div>
            </main>
    </body>

    </html>